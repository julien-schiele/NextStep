# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=a_name
POSTGRES_USER=a_username
POSTGRES_PASSWORD=a_password
DB_ENGINE=django.db.backends.postgresql
DB_HOST=database
DB_PORT=5432

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-generated-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.nextstep.julien-schiele.dev,django,caddy

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://nextstep.julien-schiele.dev
CSRF_TRUSTED_ORIGINS=https://nextstep.julien-schiele.dev,https://api.nextstep.julien-schiele.dev

# ── Cookies ───────────────────────────────────────────────────────────────────
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── Email (Resend) ────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=noreply@julien-schiele.dev

ADMIN_EMAIL=email@example.com

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.nextstep.julien-schiele.dev/api
NEXT_SERVER_API_URL=http://django:8000/api

# ── URLs ──────────────────────────────────────────────────────────────────────
FE_HOST_URL=https://nextstep.julien-schiele.dev
BE_HOST_URL=https://api.nextstep.julien-schiele.dev